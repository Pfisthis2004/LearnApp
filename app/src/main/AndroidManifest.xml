<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LearnApp">
        <activity
            android:name=".View.ui.activity.ChangePass"
            android:exported="false" />

        <service
            android:name=".Utils.MessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <activity
            android:name=".View.ui.activity.AIResultActivity"
            android:exported="false" />
        <activity
            android:name=".View.ui.activity.ChooseScenarioActivity"
            android:exported="false" />
        <activity
            android:name=".View.ui.activity.SreenChatActivity"
            android:exported="false" />
        <activity
            android:name=".View.ui.activity.EditProfileActivity"
            android:exported="false" />
        <activity
            android:name=".View.ui.begin.activity_splash"
            android:exported="true"
            android:theme="@style/Theme.LearnApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".View.ui.activity.SettingActivity"
            android:exported="false" />
        <activity
            android:name=".View.ui.activity.ArticleQuizActivity"
            android:exported="false" />
        <activity
            android:name=".View.ui.activity.DetailArticleActivity"
            android:exported="false"
            android:theme="@style/Theme.LearnApp" />
        <activity
            android:name=".View.ui.activity.DetailVocabActivity"
            android:exported="false"
            android:theme="@style/Theme.LearnApp" />
        <activity
            android:name=".View.ui.activity.SpeakingQuestionActivity"
            android:exported="false" />
        <activity
            android:name=".View.ui.activity.QuestionActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".View.ui.begin.start_studying"
            android:exported="false" />
        <activity
            android:name=".View.ui.begin.choose_level"
            android:exported="false" />
        <activity
            android:name=".View.ui.begin.reasonstudying"
            android:exported="false" />
        <activity
            android:name=".View.ui.begin.welcome"
            android:exported="false" />
        <activity
            android:name=".View.ui.begin.language"
            android:exported="false" />
        <activity
            android:name=".View.ui.activity.MainActivity"
            android:exported="false">
            <intent-filter>
                <action android:name="FLUTTER_NOTIFICATION_CLICK" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name=".View.ui.activity.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".View.ui.activity.SignUpActivity"
            android:exported="false" />
        <activity
            android:name=".View.ui.begin.welcomehome"
            android:exported="false" />
    </application>

</manifest>