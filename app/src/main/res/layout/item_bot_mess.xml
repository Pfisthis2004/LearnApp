<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp">

    <ImageView
        android:id="@+id/imgBotAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/bot"
        android:scaleType="centerCrop"
        android:layout_marginEnd="8dp"/>

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="60dp"
            android:maxWidth="280dp"
            android:background="@drawable/item_conver_background"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="28dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tvBotMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="English text here..."
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <View
                android:id="@+id/viewDivider"
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#40FFFFFF"
                android:layout_marginVertical="4dp"/>

            <TextView
                android:id="@+id/tvBotTranslation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bản dịch tiếng Việt..."
                android:textColor="#D1D1D1"
                android:textSize="13sp"
                android:textStyle="italic"
                android:visibility="gone"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:orientation="horizontal"
            android:layout_margin="4dp">

            <ImageView
                android:id="@+id/imgTranslate"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/translate" />

            <ImageView
                android:id="@+id/imgSpeaker"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/volume2" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>