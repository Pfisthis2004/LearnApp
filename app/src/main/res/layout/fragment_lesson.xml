<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorSurface"
    tools:context=".View.ui.fragment.LessonFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
   >

        <LinearLayout
            android:id="@+id/btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="30dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/leveltv"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Beginning - A1"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:textSize="20sp" />

                <ImageView
                    android:id="@+id/levelListView"
                    android:layout_width="40dp"
                    android:layout_height="30dp"
                    android:src="@drawable/outline_keyboard_arrow_down_24"
                    android:layout_gravity="center"
                    app:tint="@color/black" />

        </LinearLayout>


        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end|center_vertical">

            <LinearLayout
                android:id="@+id/streakLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/streaks"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/flame"
                    app:tint="@color/black"/>

                <TextView
                    android:id="@+id/tvStreakCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:layout_marginEnd="16dp"
                    android:textColor="#FF9800"
                    android:textStyle="bold"/>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/notification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/streakLayout"
                android:layout_centerVertical="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/bell"
                    app:tint="@color/black"/>

                <View
                    android:id="@+id/notificationBadge"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/red_dot"/>
            </FrameLayout>

        </RelativeLayout>

    </LinearLayout>


    <ImageView
        android:id="@+id/loadingImage"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:visibility="gone"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"/>
    <!-- Chapters -->
    <androidx.recyclerview.widget.RecyclerView
        android:padding="16dp"
        android:id="@+id/rcvchapter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    </LinearLayout>
</LinearLayout>