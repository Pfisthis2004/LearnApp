<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardUseCompatPadding="true"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@android:color/transparent"><LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@drawable/item_conver_background"
        android:foreground="?android:selectableItemBackground">

        <ImageView
            android:id="@+id/converIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/sparkles"
            android:contentDescription="Lesson Icon"
            android:layout_marginEnd="12dp"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/converTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tiêu đề cuộc trò chuyện"
            android:textSize="17sp"
            android:textColor="@color/white"
            android:textStyle="bold" />

    </LinearLayout>

    </androidx.cardview.widget.CardView>
</LinearLayout>